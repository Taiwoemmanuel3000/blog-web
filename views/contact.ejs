<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Contact | Bloggie</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/styles/nav.css">
    <link rel="stylesheet" href="/styles/contact.css">
</head>
<body>

    <%- include("partials/nav.ejs") %>

    <!-- Hero -->
    <section class="contact-hero">
        <div class="container">
            <h1>Get In Touch</h1>
            <p>
                Have a question, suggestion, or collaboration idea?
                We'd love to hear from you.
            </p>
        </div>
    </section>

    <!-- Contact Section -->
    <section class="contact-section">
        <div class="container">

            <div class="row g-5">

                <!-- Left Side -->
                <div class="col-lg-5">

                    <div class="contact-info">

                        <h2>Let's Connect</h2>

                        <p>
                            Feel free to reach out through the form or
                            any of the contact details below.
                        </p>

                        <div class="info-item">
                            <h5>Email</h5>
                            <p>taiwoe097@gmail.com</p>
                        </div>

                        <div class="info-item">
                            <h5>Phone</h5>
                            <p>+234 813 8432 755</p>
                        </div>

                        <div class="info-item">
                            <h5>Location</h5>
                            <p>Akure, Nigeria</p>
                        </div>

                    </div>

                </div>

                <!-- Right Side -->
                <div class="col-lg-7">

                    <div class="contact-form">

                        <form action="/contact" method="POST">

                            <div class="mb-3">
                                <label class="form-label">
                                    Full Name
                                </label>

                                <input
                                    type="text"
                                    class="form-control"
                                    name="name"
                                    required
                                >
                            </div>

                            <div class="mb-3">
                                <label class="form-label">
                                    Email Address
                                </label>

                                <input
                                    type="email"
                                    class="form-control"
                                    name="email"
                                    required
                                >
                            </div>

                            <div class="mb-3">
                                <label class="form-label">
                                    Subject
                                </label>

                                <input
                                    type="text"
                                    class="form-control"
                                    name="subject"
                                    required
                                >
                            </div>

                            <div class="mb-4">
                                <label class="form-label">
                                    Message
                                </label>

                                <textarea
                                    class="form-control"
                                    rows="6"
                                    name="message"
                                    required
                                ></textarea>
                            </div>

                            <button type="submit" class="btn-send">
                                Send Message
                            </button>

                        </form>

                    </div>

                </div>

            </div>

        </div>
    </section>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>