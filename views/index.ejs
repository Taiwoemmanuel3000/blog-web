<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/styles/main.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css">
    <link rel="stylesheet" href="/styles/nav.css">
    <title>Bloggie</title>
</head>

<body>
<%- include("partials/nav.ejs") %>

  <section class="hero">
    <div class="hero-content">
      <span class="hero-badge">CYBERSECURITY</span>

      <h1>
        Learn Cybersecurity,
        Web Development &
        Programming
      </h1>

      <p>
        Explore tutorials, coding guides, ethical hacking concepts
        and technology insights designed for beginners and professionals.
      </p>

      <div class="hero-buttons">
        <a href="#" class="btn-primary">Read Articles</a>
        <a href="#" class="btn-secondary">Start Learning</a>
      </div>
    </div>

    <div class="hero-image">
      <img src="/images/hero.png" alt="Hero Image">
    </div>
  </section>
<div class="container_center mt-4">
    <h3><%= locals.userName %></h3>
    <p><%= locals.blogPost %></p>
</div>

<%- include("partials/latest-posts.ejs") %>
<script src="/js/theme.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>